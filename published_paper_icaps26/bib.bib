	keywords = {Artificial Intelligence (cs.AI), FOS: Computer and information sciences, FOS: Mathematics, Optimization and Control (math.OC)},
}


@article{vidal_technical_2016,
	title = {Technical note: {Split} algorithm in {O}(n) for the capacitated vehicle routing problem},
	volume = {69},
	issn = {0305-0548},
